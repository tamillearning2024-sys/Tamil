:root {
  font-family: 'Manrope', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  line-height: 1.5;
  font-weight: 400;
  color: #0f172a;
  background-color: #f8fafc;
  min-height: 100%;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #f8fafc;
}

a, button {
  font-family: inherit;
}

a {
  color: inherit;
  text-decoration: none;
}

.app-shell {
  min-height: 100vh;
}

.container {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
}

.main-content {
  padding: 20px;
}

.card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
}

.btn {
  border: none;
  padding: 10px 14px;
  border-radius: 10px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.1s ease, box-shadow 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #7c3aed, #4f46e5);
  color: #fff;
  box-shadow: 0 10px 25px rgba(79, 70, 229, 0.25);
}

.btn-secondary {
  background: #e2e8f0;
  color: #0f172a;
}

.btn:hover {
  transform: translateY(-1px);
}

.input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #cbd5e1;
  border-radius: 10px;
  font-size: 15px;
}

.grid {
  display: grid;
  gap: 16px;
}

.grid-2 { grid-template-columns: repeat(2, minmax(0,1fr)); }
.grid-3 { grid-template-columns: repeat(3, minmax(0,1fr)); }
.grid-4 { grid-template-columns: repeat(4, minmax(0,1fr)); }

@media (max-width: 1024px) {
  .grid-3, .grid-4 { grid-template-columns: repeat(2, minmax(0,1fr)); }
}
@media (max-width: 768px) {
  .grid-2, .grid-3, .grid-4 { grid-template-columns: repeat(1, minmax(0,1fr)); }
}

.admin-shell {
  display: flex;
  min-height: 100vh;
  background: #f8fafc;
}

.admin-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.admin-content {
  padding: 24px 20px 32px;
}

.admin-shell.has-fixed-sidebar .admin-main {
  margin-left: 260px;
}

.admin-sidebar {
  width: 260px;
  background: #0f172a;
  color: #e2e8f0;
  padding: 24px 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: transform 0.28s ease, box-shadow 0.28s ease;
}

.admin-sidebar a {
  padding: 12px;
  border-radius: 10px;
  display: block;
  color: #e2e8f0;
}

.admin-sidebar a.active,
.admin-sidebar a:hover {
  background: rgba(255, 255, 255, 0.08);
}

.admin-sidebar.fixed {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
}

.admin-sidebar.drawer {
  position: fixed;
  inset: 0 auto 0 0;
  height: 100vh;
  transform: translateX(-100%);
  z-index: 120;
  box-shadow: 0 12px 30px rgba(0,0,0,0.25);
  width: min(260px, 80vw);
}

.admin-sidebar.drawer.is-open {
  transform: translateX(0);
}

.sidebar {
  width: 260px;
  min-height: 100vh;
  background: #0f172a;
  color: #e2e8f0;
  padding: 24px 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sidebar.mobile-hidden { display: none; }
.sidebar.mobile-drawer {
  position: fixed;
  z-index: 120;
  inset: 0;
  width: 260px;
  background: #0f172a;
  box-shadow: 0 12px 30px rgba(0,0,0,0.25);
}

.sidebar a {
  padding: 12px;
  border-radius: 10px;
  display: block;
  color: #e2e8f0;
}

.sidebar a.active,
.sidebar a:hover {
  background: rgba(255, 255, 255, 0.08);
}

.section-card:hover {
  border-color: #cbd5e1;
  box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
}

.tab-row {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}
.tab-btn {
  padding: 10px 14px;
  border-radius: 10px;
  border: 1px solid #e2e8f0;
  background: #fff;
  cursor: pointer;
}
.tab-btn.active {
  background: #0f172a;
  color: #fff;
  border-color: #0f172a;
}

.topbar {
  background: #fff;
  border-bottom: 1px solid #e2e8f0;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.topbar h1 {
  margin: 0;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.table th,
.table td {
  border-bottom: 1px solid #e2e8f0;
  padding: 10px;
  text-align: left;
  font-size: 14px;
}

.table-wrapper {
  width: 100%;
  overflow-x: auto;
}

.wrap-text {
  overflow-wrap: anywhere;
  word-break: break-word;
}

.btn-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

@media (max-width: 600px) {
  .section-header {
    display: grid;
    gap: 8px;
  }
}

.pill {
  display: inline-block;
  padding: 6px 10px;
  border-radius: 999px;
  background: #e0f2fe;
  color: #0369a1;
  font-weight: 600;
  font-size: 12px;
}

.hamburger {
  display: none;
  border: none;
  background: #0f172a;
  color: #e2e8f0;
  padding: 10px 12px;
  border-radius: 10px;
  cursor: pointer;
  flex-direction: column;
  gap: 4px;
  justify-content: center;
  align-items: center;
}

.hamburger span {
  display: block;
  width: 18px;
  height: 2px;
  background: #e2e8f0;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 110;
}

@media (max-width: 1023px) {
  .admin-shell {
    flex-direction: column;
  }

  .admin-shell.has-fixed-sidebar .admin-main {
    margin-left: 0;
  }

  .hamburger {
    display: inline-flex;
  }
}

@media (min-width: 1600px) {
  .container {
    max-width: 1600px;
  }
}
